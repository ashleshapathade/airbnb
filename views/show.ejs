<% layout("/layouts/boilerplate") %>

<style>
  /* Small Card Width */
  .main-card {
      max-width: 650px;
      margin: auto;
  }

  /* Small Image Size */
  .carousel-img {
      height: 220px;
      width: 70%;
      object-fit: cover;
      border-radius: 12px;
      margin: 0 auto; 
      display: block;
  }

  /* Card Body Padding */
  .card-body {
      padding: 1.5rem;
  }

  /* Edit/Delete Button Container */
  .btn-card-group {
      display: flex;
      gap: 10px;      /* Space between buttons */
      margin-top: 10px;
  }

  .btn-card-group .btn {
      flex: 1;        /* Make buttons equal width */
      font-size: 0.9rem;
      padding: 5px 10px;
      border-radius: 8px;
  }

  /* Review Card Styling */
  .review-card {
      padding: 8px 12px;
      margin-bottom: 8px;
      border-radius: 12px;
  }

</style>

<script>
  const mapToken = "<%= process.env.MAPBOX_TOKEN %>";
</script>

<div class="container mt-4">

  <!-- ================= LISTING CARD ================= -->
  <div class="card shadow rounded-4 mb-4 overflow-hidden main-card">

    <div class="card-body">

      <h4 class="text-center mb-3"><%= listing.title %></h4>

      <!-- IMAGE SECTION -->
      <% if (listing.image && listing.image.url && listing.extraImage && listing.extraImage.url) { %>
        <div id="listingCarousel" class="carousel slide mb-3" data-bs-ride="carousel">
          <div class="carousel-inner rounded-4">
            <div class="carousel-item active">
              <img src="<%= listing.image.url %>" class="carousel-img">
            </div>
            <div class="carousel-item">
              <img src="<%= listing.extraImage.url %>" class="carousel-img">
            </div>
          </div>
          <button class="carousel-control-prev" type="button"
                  data-bs-target="#listingCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
          </button>
          <button class="carousel-control-next" type="button"
                  data-bs-target="#listingCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
          </button>
        </div>
      <% } else if (listing.image && listing.image.url) { %>
        <img src="<%= listing.image.url %>" class="carousel-img w-100 mb-3">
      <% } %>

      <!-- INFO SECTION -->
      <div class="px-1">
        <p class="text-muted mb-2">
          <small>
            Owned by 
            <strong><%= listing.owners ? listing.owners.username : "Unknown" %></strong>
          </small>
        </p>
        <p class="mb-2"><%= listing.description %></p>
        <h6 class="text-success mb-2">
          ₹ <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %>
        </h6>
        <p class="mb-2">
          <strong>Location:</strong> <%= listing.location %>, <%= listing.country %>
        </p>
      </div>

      <!-- EDIT & DELETE -->
      <% if(currUser && listing.owners && currUser._id.equals(listing.owners._id)) { %>
        <div class="btn-card-group">
          <a href="/listings/<%= listing._id %>/edit" class="btn btn-success">
            <i class="fas fa-edit"></i> Edit
          </a>
          <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
            <button class="btn btn-danger">
              <i class="fas fa-trash-alt"></i> Delete
            </button>
          </form>
        </div>
      <% } %>

    </div>
  </div>

  <!-- ================= REVIEW CARD ================= -->
  <div class="card shadow rounded-4 mb-4 p-3 main-card">
    <h5 class="mb-3">Reviews</h5>

    <% if(currUser) { %>
      <form method="POST" action="/listings/<%= listing._id %>/reviews" novalidate>
        <div class="mb-2">
          <label class="form-label">Rating</label>
          <fieldset class="starability-slot">
            <input type="radio" id="rate1" name="review[rating]" value="1" checked />
            <label for="rate1">1</label>
            <input type="radio" id="rate2" name="review[rating]" value="2" />
            <label for="rate2">2</label>
            <input type="radio" id="rate3" name="review[rating]" value="3" />
            <label for="rate3">3</label>
            <input type="radio" id="rate4" name="review[rating]" value="4" />
            <label for="rate4">4</label>
            <input type="radio" id="rate5" name="review[rating]" value="5" />
            <label for="rate5">5</label>
          </fieldset>
        </div>

        <div class="mb-2">
          <textarea name="review[comment]" class="form-control" rows="3" placeholder="Write your review..." required></textarea>
        </div>

        <button class="btn btn-sm btn-primary">Submit Review</button>
      </form>
      <hr class="my-3">
    <% } %>

    <% if(listing.reviews.length > 0) { %>
      <% listing.reviews.forEach(review => { %>
        <div class="card review-card shadow-sm">
          <small><strong>@<%= review.author.username %></strong></small>
          <p class="starability-result" data-rating="<%= review.rating %>"></p>
          <small><%= review.comment %></small>
          <% if(currUser && review.author._id.equals(currUser._id)) { %>
            <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="mt-1">
              <button class="btn btn-sm btn-dark">Delete</button>
            </form>
          <% } %>
        </div>
      <% }) %>
    <% } else { %>
      <p class="text-muted">No reviews yet.</p>
    <% } %>

  </div>

  <!-- ================= MAP CARD ================= -->
  <div class="card shadow rounded-4 p-3 mb-4 main-card">
    <h6 class="mb-2">Where you'll be</h6>
    <div id="map" style="height:250px; border-radius:12px;"></div>
  </div>

</div>

<script src="/js/map.js"></script>